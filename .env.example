# ============================================================
# .env.example — Variables de entorno del proyecto SGD-UCI
# INSTRUCCIÓN: copiar a .env.local y cambiar los valores sensibles
#   cp .env.example .env.local
# NUNCA hacer commit del archivo .env real
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=docente_db
POSTGRES_USER=docente
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# ── Node.js / Express ────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=SGD-UCI
API_URL=http://localhost:3000

# ── Conexión completa a la BD (usada por pg Pool) ────────────
DATABASE_URL=postgresql://docente:change_me_in_production@postgres:5432/docente_db

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
