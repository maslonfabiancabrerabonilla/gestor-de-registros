{
  "info": {
    "name": "SGD-UCI API",
    "_postman_id": "sgd-uci-local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "{{base}}/health" }
    },
    {
      "name": "Grupos / Listar",
      "request": { "method": "GET", "url": "{{base}}/api/grupos" }
    },
    {
      "name": "Grupos / Crear",
      "request": {
        "method": "POST",
        "url": "{{base}}/api/grupos",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Grupo C\",\n  \"asignatura\": \"Bases de Datos\",\n  \"semestre\": \"2026-1\"\n}" }
      }
    },
    {
      "name": "Estudiantes / Listar (Grupo 1)",
      "request": { "method": "GET", "url": "{{base}}/api/grupos/1/estudiantes" }
    },
    {
      "name": "Estudiantes / Crear manual",
      "request": {
        "method": "POST",
        "url": "{{base}}/api/grupos/1/estudiantes",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Carlos Pérez\"\n}" }
      }
    },
    {
      "name": "Estudiantes / Estadísticas (estudiante 1)",
      "request": { "method": "GET", "url": "{{base}}/api/grupos/1/estudiantes/1/estadisticas" }
    },
    {
      "name": "Turnos / Listar (Grupo 1)",
      "request": { "method": "GET", "url": "{{base}}/api/grupos/1/turnos" }
    },
    {
      "name": "Turnos / Crear",
      "request": {
        "method": "POST",
        "url": "{{base}}/api/grupos/1/turnos",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"fecha\": \"2026-04-05\",\n  \"tipo\": \"PP\",\n  \"descripcion\": \"Prueba parcial\"\n}" }
      }
    },
    {
      "name": "Registros / Batch Save",
      "request": {
        "method": "POST",
        "url": "{{base}}/api/registros/batch-save",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"turno_id\": 1,\n  \"registros\": [\n    { \"estudiante_id\": 1, \"asistencia\": \"A\", \"calificacion\": 4.2 }\n  ]\n}" }
      }
    },
    {
      "name": "Registros / Ver turno",
      "request": { "method": "GET", "url": "{{base}}/api/registros/turno/1" }
    },
    {
      "name": "Reportes / Generar Corte (descarga xlsx)",
      "request": {
        "method": "POST",
        "url": "{{base}}/api/grupos/1/reportes/generar-corte",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"nombre_reporte\": \"Corte Abril 2026\"\n}" }
      }
    },
    {
      "name": "Exportar / Matriz Completa (descarga xlsx)",
      "request": { "method": "GET", "url": "{{base}}/api/grupos/1/exportar/matriz-completa" }
    },
    {
      "name": "Auditoría / Ver historial",
      "request": { "method": "GET", "url": "{{base}}/api/grupos/1/auditoria" }
    }
  ]
}
